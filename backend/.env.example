# Environment Configuration Template
# Copy this to .env and fill in your values

# ============ App Configuration ============
DEBUG=True
APP_NAME="Multi-Agentic RE Tool"

# ============ LLM Provider Configuration ============
# Each LLM role (main / analysis / formalize) can independently target any of:
#   ollama | openai | anthropic | gemini
#
# Defaults to "ollama" everywhere for backward compatibility.
# When a role's *_LLM_PROVIDER is empty, it inherits LLM_PROVIDER.
# When a role's *_LLM_MODEL is empty and the resolved provider is "ollama",
# it falls back to OLLAMA_MODEL (or the legacy OLLAMA_ANALYSIS_MODEL /
# OLLAMA_FORMALIZE_MODEL settings further down).

# --- Main role: clarification question generation ---
LLM_PROVIDER=ollama
LLM_MODEL=

# --- Analysis role: smell detection + gap scoring ---
# Leave provider empty to inherit LLM_PROVIDER.
ANALYSIS_LLM_PROVIDER=
ANALYSIS_LLM_MODEL=

# --- Formalize role: ISO 29148 atomization ---
# Leave provider empty to inherit LLM_PROVIDER.
FORMALIZE_LLM_PROVIDER=
FORMALIZE_LLM_MODEL=

# --- Cloud provider API keys (only needed when that provider is selected) ---
# OpenAI: examples — gpt-4o-mini, gpt-4o, gpt-4-turbo
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# OPENAI_API_BASE=  # optional, e.g. for Azure OpenAI or a proxy gateway

# Anthropic: examples — claude-3-5-sonnet-latest, claude-3-5-haiku-latest
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_API_KEY=

# Google Gemini: examples — gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
GOOGLE_API_KEY=

# ============ Ollama LLM Configuration ============
# Used when any *_LLM_PROVIDER resolves to "ollama" (the default).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7

# Model for smell detection + gap scoring; defaults to OLLAMA_MODEL if unset.
# Set to a smaller/faster model (e.g. phi3:mini) to cut per-request latency.
OLLAMA_ANALYSIS_MODEL=

# Model for ISO 29148 formalization step; defaults to OLLAMA_MODEL if unset.
# Set to a larger/higher-quality model (e.g. qwen2.5:14b-instruct-q4_K_M)
# for tighter ISO output without slowing down question generation.
OLLAMA_FORMALIZE_MODEL=

# ============ Whisper Configuration ============
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# ============ FastAPI Server ============
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=4

# ============ File Upload Configuration ============
UPLOAD_DIR=data/uploads
MAX_FILE_SIZE=104857600  # 100MB

# ============ LangGraph Checkpointing ============
# Options: memory, sqlite, postgres
CHECKPOINTER_TYPE=memory
CHECKPOINT_DB_PATH=data/checkpoints.db

# ============ Jira Integration (Optional) ============
JIRA_ENABLED=True
JIRA_SERVER_URL=https://your-jira-instance.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-api-token
JIRA_PROJECT_KEY=PROJ

# ============ Trello Integration (Optional) ============
TRELLO_ENABLED=True
TRELLO_API_KEY=your-api-key
TRELLO_API_TOKEN=your-api-token
TRELLO_BOARD_ID=your-board-id

# ============ Logging ============
LOG_LEVEL=INFO
